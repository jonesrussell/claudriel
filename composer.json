{
    "name": "jonesrussell/claudriel",
    "description": "Claudriel — AI personal operations system",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.4",
        "waaseyaa/github": "v0.1.0-alpha.9",
        "waaseyaa/ai-pipeline": "v0.1.0-alpha.9",
        "waaseyaa/api": "v0.1.0-alpha.9",
        "waaseyaa/cli": "v0.1.0-alpha.9",
        "waaseyaa/config": "v0.1.0-alpha.9",
        "waaseyaa/core": "v0.1.0-alpha.9",
        "waaseyaa/database-legacy": "v0.1.0-alpha.9",
        "waaseyaa/entity": "v0.1.0-alpha.9",
        "waaseyaa/entity-storage": "v0.1.0-alpha.9",
        "waaseyaa/foundation": "v0.1.0-alpha.9",
        "waaseyaa/path": "v0.1.0-alpha.9",
        "waaseyaa/routing": "v0.1.0-alpha.9",
        "waaseyaa/ssr": "v0.1.0-alpha.9",
        "waaseyaa/user": "v0.1.0-alpha.9"
    },
    "require-dev": {
        "deployer/deployer": "^7.5",
        "laravel/pint": "^1.28",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.5",
        "symfony/event-dispatcher": "^7.0"
    },
    "autoload": {
        "psr-4": { "Claudriel\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "Claudriel\\Tests\\": "tests/" }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "pint --test",
        "format": "pint",
        "analyse": "phpstan analyse"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "extra": {
        "waaseyaa": {
            "providers": [
                "Claudriel\\Provider\\ClaudrielServiceProvider",
                "Claudriel\\Provider\\I18nServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
